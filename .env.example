# Domain Configuration
PRIMARY_DOMAIN=yourdomain.com
EMAIL=admin@yourdomain.com

# Nginx Configuration
NGINX_WORKER_PROCESSES=auto
NGINX_WORKER_CONNECTIONS=1024

# SSL Configuration (for Let's Encrypt)
CERTBOT_EMAIL=${EMAIL}
CERTBOT_DOMAINS=${PRIMARY_DOMAIN}

# Optional: Staging mode for testing (uses Let's Encrypt staging server)
# CERTBOT_STAGING=1

# Network Configuration
DOCKER_NETWORK_NAME=infrastructure-web
